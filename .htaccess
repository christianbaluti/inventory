<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    SetEnvIfNoCase Origin "^https://inventory-lilac-alpha\.vercel\.app$" CORS_ORIGIN=$0
    SetEnvIfNoCase Origin "^https://[a-z0-9-]+\.vercel\.app$" CORS_ORIGIN=$0
    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept, Origin" env=CORS_ORIGIN
    Header always set Vary "Origin" env=CORS_ORIGIN
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ - [R=204,L]
    RewriteRule ^(\.env|composer\.(json|lock)|package(-lock)?\.json|artisan|vite\.config\.js|vite\.frontend\.config\.js|phpunit\.xml|README\.md|DEPLOYMENT\.md)$ - [F,L]
    RewriteRule ^(app|bootstrap|config|database|node_modules|resources|routes|storage|tests|vendor)(/|$) - [F,L]
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
